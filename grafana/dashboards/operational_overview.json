    {
      "id": 6,
      "type": "barchart",
      "title": "Top origin to destination regions",
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 13
      },
      "datasource": {
        "type": "postgres",
        "uid": "postgres-flight-insights"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  departure_region || ' → ' || arrival_region AS route_region,\n  COUNT(*) AS flights\nFROM flight_aircraft_routes\nWHERE run_id = (\n  SELECT run_id\n  FROM flight_aircraft_routes\n  ORDER BY id DESC\n  LIMIT 1\n)\n  AND departure_region IS NOT NULL\n  AND arrival_region IS NOT NULL\nGROUP BY 1\nORDER BY flights DESC\nLIMIT 20;"
        }
      ],
      "options": {
        "orientation": "horizontal",
        "xField": "route_region",
        "showValue": "always",
        "stacking": "none",
        "groupWidth": 0.58,
        "barWidth": 0.72,
        "legend": {
          "displayMode": "list",
